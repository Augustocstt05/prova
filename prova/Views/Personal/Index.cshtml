@model IEnumerable<prova.Models.Personal>

@{
    ViewData["Title"] = "Lista de Personais";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Personais Cadastrados</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Novo Personal
        </a>
    </div>

    <table class="table table-hover table-striped border shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Nome)</th>
                <th>@Html.DisplayNameFor(model => model.Especialidade)</th>
                <th class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nome</td>
                        <td>@item.Especialidade</td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.PersonalID" class="btn btn-sm btn-warning">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.PersonalID" class="btn btn-sm btn-info text-white">Ver</a>
                                <a asp-action="Delete" asp-route-id="@item.PersonalID" class="btn btn-sm btn-danger">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center text-muted">Nenhum personal cadastrado até o momento.</td>
                </tr>
            }
        </tbody>
    </table>
</div>